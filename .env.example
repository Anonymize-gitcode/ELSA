# ELSA — LLM API configuration
#
# Copy this file to `.env` and fill in your key(s):   cp .env.example .env
# `.env` is loaded automatically by execution.py, and every pipeline step
# inherits these values — so API keys live in ONE place, are never hard-coded in
# the scripts, and are never committed (`.env` is git-ignored). You may also just
# `export` these as normal environment variables instead of using a .env file.

# OpenAI, used when running with `--LLM gpt-3.5-turbo`
OPENAI_API_KEY=

# Optional: point the gpt-3.5-turbo code path at ANY OpenAI-compatible endpoint
# (e.g. a free/open model) WITHOUT editing code. Leave both unset to use the
# standard OpenAI endpoint with gpt-3.5-turbo (default, unchanged behavior).
#   Groq (hosted Llama):  OPENAI_API_BASE=https://api.groq.com/openai/v1   OPENAI_MODEL=llama-3.1-8b-instant   (OPENAI_API_KEY=gsk_...)
#   Local Ollama:         OPENAI_API_BASE=http://localhost:11434/v1        OPENAI_MODEL=llama3.1               (OPENAI_API_KEY=ollama)
OPENAI_API_BASE=
OPENAI_MODEL=

# OpenAI-compatible endpoint, used when running with `--LLM Deepseek`.
# Works with DeepSeek's hosted API or any OpenAI-compatible server
# (e.g. a local Ollama server for open models: base_url http://localhost:11434/v1).
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
